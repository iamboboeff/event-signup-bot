# --- Telegram ---
# Токен от @BotFather (вид: 1234567890:AAH...). НЕ коммитить.
BOT_TOKEN=

# ID группы для уведомлений о новых записях.
# Получишь так: создай группу, добавь бота, отправь в группе команду /id — бот пришлёт chat_id.
GROUP_CHAT_ID=

# Твой Telegram user id (узнать тоже через /id). Через запятую, если несколько админов.
ADMIN_IDS=

# --- Google Sheets (веб-приложение Apps Script) — источник правды для записей ---
SHEET_WEBAPP_URL=

# --- Cloud Run (webhook) ---
# Публичный URL сервиса Cloud Run (например https://event-bot-xxxx.run.app).
# Если пусто — бот работает локально через long-polling.
WEBHOOK_URL=
# Секрет для проверки запросов от Telegram (необязательно; по умолчанию берётся из токена).
WEBHOOK_SECRET=
